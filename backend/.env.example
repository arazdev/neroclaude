# ─── Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Polymarket ──────────────────────────────────────────
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=0x...your_wallet_private_key
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ─── Risk Limits ─────────────────────────────────────────
MAX_POSITION_USDC=100.0
MAX_ORDER_USDC=25.0
MAX_OPEN_ORDERS=5
MIN_LIQUIDITY_USDC=500.0

# ─── Trading Style ───────────────────────────────────────
# Maximum days until market expiration (short-term trading)
# 1 = same-day trades only
# 5 = weekly trades
# 30 = monthly trades (default)
MAX_DAYS_TO_EXPIRATION=30

# ─── Bot Settings ────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
DRY_RUN=true
LOG_LEVEL=INFO
# Modes: claude, arb, cross, mm, all
BOT_MODE=all

# ─── Arbitrage Scanner ───────────────────────────────────
ARB_FEE_BUFFER=0.02
ARB_MIN_PROFIT_PCT=0.5
ARB_MAX_USDC=25.0
ARB_SCAN_INTERVAL=5

# ─── Market Making ───────────────────────────────────────
MM_MAX_USDC=25.0
MM_MAX_MARKETS=3

# ─── API Server (for Vercel dashboard) ───────────────────
API_PORT=8080
API_SECRET=change-me-to-a-random-string
CORS_ORIGINS=https://your-app.vercel.app
